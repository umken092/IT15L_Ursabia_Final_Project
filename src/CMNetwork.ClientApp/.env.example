# API Configuration
# Default: https://localhost:7210/api
VITE_API_URL=https://localhost:7210/api

# reCAPTCHA v3 site key (public key)
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_V3_SITE_KEY

# Local backend environment settings
ASPNETCORE_ENVIRONMENT=Development

# Database connection (backend use only; keep server-side and never expose in client bundles)
CMN_DB_CONNECTION_STRING=Server=localhost;Database=CMNetwork;Trusted_Connection=True;TrustServerCertificate=True;

# You can also use a relative path if the API is on the same domain:
# VITE_API_URL=/api
