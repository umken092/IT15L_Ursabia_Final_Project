{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "UseMonsterAsp": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=CMNetwork;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "MonsterAspConnection": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "https://localhost:5173",
      "https://localhost:3000"
    ]
  },
  "Jwt": {
    "Secret": "set-in-dotnet-user-secrets",
    "Issuer": "cmnetwork",
    "Audience": "cmnetwork-client"
  },
  "PayMongo": {
    "PublicKey": "set-in-dotnet-user-secrets",
    "SecretKey": "set-in-dotnet-user-secrets"
  }
}
